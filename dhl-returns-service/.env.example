# --- Modus / Verhalten ---
MODE=AUTO                 # AUTO = genehmigen+labeln bei Anfrage | GATE = labeln nach Genehmigung
DRY_RUN=true              # true = nichts erzeugen/schreiben, nur loggen
POLL_LOOKBACK_DAYS=30     # nur Bestellungen der letzten N Tage prüfen
MAX_PER_RUN=50            # Sicherheits-Obergrenze verarbeiteter Retouren pro Lauf

# --- Shopify ---
SHOPIFY_SHOP=oneal-europe.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2025-07

# --- DHL Parcel DE Returns (OAuth2 ROPC) ---
DHL_BASE=https://api-eu.dhl.com           # Test/Integration ggf. abweichende Basis-URL
DHL_CLIENT_ID=xxxx                         # API Key
DHL_CLIENT_SECRET=xxxx                     # API Secret
DHL_GKP_USER=xxxx                          # Geschäftskundenportal-Benutzer (Prod). Sandbox: user-valid
DHL_GKP_PASSWORD=xxxx                      # Prod-Passwort. Sandbox: SandboxPasswort2023!
DHL_LABEL_TYPE=SHIPMENT_LABEL              # SHIPMENT_LABEL | QR_LABEL | BOTH

# Land -> receiverId (mit Abrechnungsnummer). Prod: echte IDs aus GKP. Sandbox-Test: deu/aut/fra/che...
RECEIVER_IDS={"DE":"REPLACE_DE","AT":"REPLACE_AT"}

# --- Guardrails (nur AUTO) ---
MAX_ORDER_AGE_DAYS=60
BLOCKED_REASONS=OTHER
