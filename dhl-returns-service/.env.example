# --- Modus / Verhalten ---
MODE=AUTO                 # AUTO = genehmigen+labeln | GATE = nur labeln nach Genehmigung
DRY_RUN=true              # true = nichts erzeugen/schreiben, nur loggen
POLL_LOOKBACK_DAYS=30
MAX_PER_RUN=50            # global über alle Stores
ONLY_ORDERS=             # leer = alle; für Tests einzelne Bestellnummern

# --- Shopify: ALLE Marken in einem JSON-Array (eine Zeile) ---
# Jede Marke = eigene Dev-Dashboard-App (eigene Client ID/Secret). DHL ist geteilt.
SHOPIFY_STORES=[{"key":"oneal","shop":"oneal-europe.myshopify.com","clientId":"xxx","clientSecret":"yyy"},{"key":"one","shop":"oneal-one.myshopify.com","clientId":"xxx","clientSecret":"yyy"},{"key":"kini","shop":"oneal-kini.myshopify.com","clientId":"xxx","clientSecret":"yyy"}]
SHOPIFY_API_VERSION=2025-07

# --- DHL Parcel DE Returns (geteilt über alle Marken) ---
DHL_BASE=https://api-eu.dhl.com
DHL_CLIENT_ID=xxxx
DHL_CLIENT_SECRET=xxxx
DHL_GKP_USER=xxxx
DHL_GKP_PASSWORD=xxxx
DHL_LABEL_TYPE=SHIPMENT_LABEL
RECEIVER_IDS={"DE":"deu","AT":"aut","CH":"che","GB":"gbr","FR":"fra","IT":"ita","ES":"esp","NL":"nld","BE":"bel"}

# --- Guardrails ---
MAX_ORDER_AGE_DAYS=60
BLOCKED_REASONS=
CUSTOMS_COUNTRIES=CH,GB
DEFAULT_ITEM_WEIGHT_KG=0.5
