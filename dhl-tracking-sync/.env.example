# --- Shopify ---
SHOPIFY_SHOP=oneal-europe.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx              # Custom App Admin API Token
SHOPIFY_API_VERSION=2025-07

# --- DHL Shipment Tracking (Unified) ---
DHL_API_KEY=xxxxxxxxxxxxxxxx               # API-Key aus dem DHL Developer Portal (Tracking-Unified)
DHL_TRACKING_BASE=https://api-eu.dhl.com   # Produktion (Europe). Sandbox: https://api-sandbox.dhl.com

# --- Verhalten ---
LOOKBACK_DAYS=30          # nur Bestellungen der letzten N Tage prüfen
DRY_RUN=true              # true = nur loggen, KEINE Events schreiben (zum Testen!)
DHL_RATE_DELAY_MS=350     # Pause zwischen DHL-Calls
MAX_TRACK_CALLS=240       # harte Obergrenze DHL-Calls pro Lauf (Limit: 250/Tag!)
